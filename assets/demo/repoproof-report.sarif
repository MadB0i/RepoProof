                "markdown": "Unbounded retry: while\\(true\\) loop with retry"
              },
              "helpUri": "https://repoproof.dev/docs/rules/unbounded-retries",
              "help": {
                "text": "Add a maximum retry count or timeout to cap retries.",
                "markdown": "Add a maximum retry count or timeout to cap retries."
              },
              "properties": {
                "category": "error-handling-reliability",
                "scorePenalty": 4,
                "severity": "warning"
              }
            },
            {
