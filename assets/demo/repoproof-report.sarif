                "scorePenalty": 4,
                "severity": "warning"
              }
            },
            {
              "id": "missing-gitignore",
              "name": "Missing .gitignore file",
              "fullDescription": {
                "text": "Project does not have a .gitignore file",
                "markdown": "Project does not have a .gitignore file"
              },
              "helpUri": "https://repoproof.dev/docs/rules/missing-gitignore",
              "help": {
                "text": "Create a .gitignore file for your project.",
                "markdown": "Create a .gitignore file for your project."
              },
              "properties": {
                "category": "security-configuration",
                "scorePenalty": 5,
                "severity": "warning"
              }
            },
            {
              "id": "empty-catch",
              "name": "Empty catch blocks",
              "fullDescription": {
                "text": "Empty catch block that silently swallows errors",
                "markdown": "Empty catch block that silently swallows errors"
              },
              "helpUri": "https://repoproof.dev/docs/rules/empty-catch",
              "help": {
                "text": "Handle or log errors in catch blocks.",
                "markdown": "Handle or log errors in catch blocks."
              },
              "properties": {
                "category": "error-handling-reliability",
                "scorePenalty": 4,
                "severity": "warning"
              }
            },
            {
              "id": "no-http-timeout",
              "name": "HTTP requests without timeout configuration",
              "fullDescription": {
                "text": "HTTP request without timeout: \"fetch(\"",
                "markdown": "HTTP request without timeout: \"fetch\\(\""
              },
              "helpUri": "https://repoproof.dev/docs/rules/no-timeout",
              "help": {
                "text": "Add a timeout to this HTTP request.",
                "markdown": "Add a timeout to this HTTP request."
              },
              "properties": {
                "category": "error-handling-reliability",
                "scorePenalty": 3,
                "severity": "warning"
              }
            },
            {
              "id": "unbounded-retries",
              "name": "Unbounded retry loops",
              "fullDescription": {
