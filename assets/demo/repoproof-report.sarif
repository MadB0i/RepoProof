{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "RepoProof",
          "version": "1.0.0",
          "informationUri": "https://github.com/MadB0i/RepoProof",
          "rules": [
            {
              "id": "todo-fixme",
              "name": "TODO/FIXME markers in source code",
              "fullDescription": {
                "text": "File contains 4 TODO/FIXME markers",
                "markdown": "File contains 4 TODO/FIXME markers"
              },
              "helpUri": "https://repoproof.dev/docs/rules/todo-fixme",
              "help": {
                "text": "Remove or resolve all TODO/FIXME markers.",
                "markdown": "Remove or resolve all TODO/FIXME markers."
              },
              "properties": {
                "category": "incomplete-implementation",
                "scorePenalty": 2,
                "severity": "warning"
              }
            },
            {
              "id": "not-implemented",
              "name": "Not implemented code paths",
              "fullDescription": {
                "text": "Found not-implemented code path: \"throw new Error('not implemented')\"",
                "markdown": "Found not-implemented code path: \"throw new Error\\('not implemented'\\)\""
              },
              "helpUri": "https://repoproof.dev/docs/rules/not-implemented",
              "help": {
                "text": "Implement the missing functionality.",
                "markdown": "Implement the missing functionality."
              },
              "properties": {
                "category": "incomplete-implementation",
                "scorePenalty": 5,
                "severity": "error"
              }
            },
            {
              "id": "empty-function",
              "name": "Empty function bodies",
              "fullDescription": {
                "text": "Found empty function body: it('', function() {}",
                "markdown": "Found empty function body: it\\('', function\\(\\) {}"
              },
              "helpUri": "https://repoproof.dev/docs/rules/empty-function",
              "help": {
                "text": "Implement or remove the empty function.",
                "markdown": "Implement or remove the empty function."
              },
              "properties": {
                "category": "incomplete-implementation",
                "scorePenalty": 3,
                "severity": "warning"
              }
            },
            {
              "id": "placeholder-text",
              "name": "Placeholder text in source code",
              "fullDescription": {
                "text": "File contains 2 placeholder text instance(s)",
                "markdown": "File contains 2 placeholder text instance\\(s\\)"
              },
              "helpUri": "https://repoproof.dev/docs/rules/placeholder-text",
              "help": {
                "text": "Replace placeholder text with actual content.",
                "markdown": "Replace placeholder text with actual content."
              },
              "properties": {
                "category": "incomplete-implementation",
                "scorePenalty": 2,
                "severity": "warning"
              }
            },
            {
              "id": "commented-code",
              "name": "Commented-out code blocks",
              "fullDescription": {
                "text": "Found 16 consecutive lines of commented code",
                "markdown": "Found 16 consecutive lines of commented code"
              },
              "helpUri": "https://repoproof.dev/docs/rules/commented-code",
              "help": {
                "text": "Remove commented-out code.",
                "markdown": "Remove commented-out code."
              },
              "properties": {
                "category": "incomplete-implementation",
                "scorePenalty": 3,
                "severity": "warning"
              }
            },
            {
              "id": "mock-data",
              "name": "Hardcoded mock data in source code",
              "fullDescription": {
                "text": "Suspicious mock/test data: \"admin\"",
                "markdown": "Suspicious mock/test data: \"admin\""
              },
              "helpUri": "https://repoproof.dev/docs/rules/mock-data",
              "help": {
                "text": "Remove mock data from production code.",
                "markdown": "Remove mock data from production code."
              },
              "properties": {
                "category": "incomplete-implementation",
                "scorePenalty": 3,
                "severity": "warning"
              }
            },
            {
              "id": "missing-tests",
              "name": "Missing test files for source files",
              "fullDescription": {
                "text": "Missing test files for 1 source file(s) in src",
                "markdown": "Missing test files for 1 source file\\(s\\) in src"
              },
              "helpUri": "https://repoproof.dev/docs/rules/missing-tests",
              "help": {
                "text": "Add test files for: src/helper.js",
                "markdown": "Add test files for: src/helper.js"
              },
              "properties": {
                "category": "tests",
                "scorePenalty": 3,
                "severity": "warning"
              }
            },
            {
              "id": "test-echo-command",
              "name": "Test script is an echo placeholder",
              "fullDescription": {
                "text": "Test script is just an echo command: \"echo \"Error: no test specified\" && exit 1\"",
                "markdown": "Test script is just an echo command: \"echo \"Error: no test specified\" && exit 1\""
              },
              "helpUri": "https://repoproof.dev/docs/rules/test-echo-command",
              "help": {
                "text": "Replace echo with actual test runner command.",
                "markdown": "Replace echo with actual test runner command."
              },
              "properties": {
                "category": "tests",
                "scorePenalty": 8,
                "severity": "error"
              }
            },
            {
              "id": "hardcoded-secrets",
              "name": "Hardcoded secrets in source code",
              "fullDescription": {
                "text": "API key detected in source code in src/__tests__/test.js",
                "markdown": "API key detected in source code in src/\\_\\_tests\\_\\_/test.js"
              },
              "helpUri": "https://repoproof.dev/docs/rules/hardcoded-secrets",
              "help": {
                "text": "Remove hardcoded secret and use environment variables.",
                "markdown": "Remove hardcoded secret and use environment variables."
              },
              "properties": {
                "category": "security-configuration",
                "scorePenalty": 10,
                "severity": "error"
              }
            },
            {
              "id": "unsafe-eval",
              "name": "Use of eval() or dynamic code execution",
              "fullDescription": {
                "text": "Use of eval( detected",
                "markdown": "Use of eval\\( detected"
              },
              "helpUri": "https://repoproof.dev/docs/rules/unsafe-eval",
              "help": {
                "text": "Replace eval/dynamic execution with safer alternatives.",
                "markdown": "Replace eval/dynamic execution with safer alternatives."
              },
              "properties": {
                "category": "security-configuration",
                "scorePenalty": 5,
                "severity": "error"
              }
            },
            {
              "id": "wildcard-cors",
              "name": "Wildcard CORS configuration",
              "fullDescription": {
                "text": "Wildcard CORS configuration found: \"Header('Access-Control-Allow-Origin', '*'\"",
                "markdown": "Wildcard CORS configuration found: \"Header\\('Access-Control-Allow-Origin', '\\*'\""
              },
              "helpUri": "https://repoproof.dev/docs/rules/wildcard-cors",
              "help": {
                "text": "Restrict CORS to specific origins instead of using '*'.",
                "markdown": "Restrict CORS to specific origins instead of using '\\*'."
              },
              "properties": {
                "category": "security-configuration",
                "scorePenalty": 5,
                "severity": "error"
              }
            },
            {
              "id": "debug-enabled",
              "name": "Debug mode enabled by default",
              "fullDescription": {
                "text": "Debug/development mode enabled: \"debug: true,\"",
                "markdown": "Debug/development mode enabled: \"debug: true,\""
              },
              "helpUri": "https://repoproof.dev/docs/rules/debug-enabled",
              "help": {
                "text": "Disable debug mode for production deployments.",
                "markdown": "Disable debug mode for production deployments."
              },
              "properties": {
