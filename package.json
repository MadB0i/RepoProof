{
  "name": "repoproof",
  "version": "1.0.1",
  "description": "Fast, deterministic, local-first CLI for auditing repository quality risks in AI-generated and rapidly generated software projects",
  "keywords": [
    "repository-quality",
    "code-audit",
    "ai-generated-code",
    "cli",
    "static-analysis",
    "code-review",
    "quality-gate"
  ],
  "homepage": "https://github.com/MadB0i/RepoProof#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MadB0i/RepoProof.git"
  },
  "bugs": {
    "url": "https://github.com/MadB0i/RepoProof/issues"
  },
  "license": "MIT",
  "author": "MadB0i",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "repoproof": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"docs/**/*.md\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"docs/**/*.md\" \"*.md\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/smoke.js",
    "verify": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build && pnpm smoke",
    "prepublishOnly": "pnpm verify"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitest/coverage-v8": "2.1.9",
    "eslint": "^9.15.0",
    "playwright": "^1.61.1",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
